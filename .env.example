# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://minexcrm:minexcrm_dev@localhost:5432/minexcrm
POSTGRES_PASSWORD=minexcrm_dev

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_string_minimum_32_chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# IAM user needs: s3:PutObject, s3:GetObject, s3:DeleteObject, s3:HeadObject
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET=minexcrm-files-production

# ── WhatsApp Business (Meta Cloud API) ────────────────────────────────────────
# Dashboard: developers.facebook.com → your app → WhatsApp → API Setup
WA_VERIFY_TOKEN=your_own_random_verify_token
WA_APP_SECRET=your_meta_app_secret_from_app_settings
WA_PHONE_ID=your_whatsapp_phone_number_id
WA_ACCESS_TOKEN=your_permanent_or_long_lived_access_token

