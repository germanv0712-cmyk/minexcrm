generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenancy ────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  short     String   @db.VarChar(10)
  nit       String   @unique
  logoUrl   String?
  plan      Plan     @default(STARTER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  clients      Client[]
  projects     Project[]
  wells        Well[]
  equipment    Equipment[]
  opportunities Opportunity[]
  incidents    Incident[]
  permits      Permit[]
  visits       Visit[]
  files        File[]
  webhooks     Webhook[]
  auditLogs    AuditLog[]
  refreshTokens RefreshToken[]

  @@map("tenants")
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole  @default(VIEWER)
  avatar       String?   @db.VarChar(4)
  color        String?   @db.VarChar(9)
  phone        String?
  position     String?
  eps          String?
  arl          String?
  shift        String?
  projectId    String?
  mfaSecret    String?
  mfaEnabled   Boolean   @default(false)
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  certifications Certification[]
  auditLogs     AuditLog[]
  ownedProjects  Project[]      @relation("ProjectOwner")
  ownedOpps      Opportunity[]  @relation("OpportunityOwner")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  FIELD
  VIEWER
  PORTAL
}

model RefreshToken {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

model Client {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  nit            String
  contact        String
  email          String
  phone          String
  region         String
  tier           String   @default("C") @db.VarChar(1)
  logo           String?  @db.VarChar(4)
  color          String?  @db.VarChar(9)
  ltv            Decimal  @default(0) @db.Decimal(18, 2)
  nextMeeting    DateTime?
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects     Project[]
  opportunities Opportunity[]
  contacts     Contact[]

  @@unique([tenantId, nit])
  @@index([tenantId])
  @@map("clients")
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  position  String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("contacts")
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id             String        @id @default(cuid())
  tenantId       String
  clientId       String
  ownerId        String
  code           String
  name           String
  service        String
  region         String
  lat            Float?
  lng            Float?
  status         ProjectStatus @default(ACTIVE)
  progress       Int           @default(0) @db.SmallInt
  startDate      DateTime
  endDate        DateTime
  contractValue  Decimal       @db.Decimal(18, 2)
  billed         Decimal       @default(0) @db.Decimal(18, 2)
  description    String?
  coverColor     String?       @db.VarChar(9)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client      @relation(fields: [clientId], references: [id])
  owner     User        @relation("ProjectOwner", fields: [ownerId], references: [id])
  wells     Well[]
  visits    Visit[]
  milestones Milestone[]
  alerts    Alert[]
  files     File[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([clientId])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  ALERT
  COMPLETED
  CANCELLED
}

model Milestone {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  dueDate     DateTime
  completedAt DateTime?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model Alert {
  id        String      @id @default(cuid())
  projectId String
  type      AlertType
  message   String
  severity  AlertSeverity @default(INFO)
  resolved  Boolean     @default(false)
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

enum AlertType {
  DEADLINE
  BUDGET
  HSE
  EQUIPMENT
  PERSONNEL
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ─── Pipeline ─────────────────────────────────────────────────────────────────

model Opportunity {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String
  ownerId   String
  name      String
  amount    Decimal  @db.Decimal(18, 2)
  prob      Int      @default(50) @db.SmallInt
  stage     String
  closeDate DateTime
  nextAction String?
  notes     String?
  wonAt     DateTime?
  lostAt    DateTime?
  lostReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id])
  owner  User   @relation("OpportunityOwner", fields: [ownerId], references: [id])

  @@index([tenantId])
  @@map("opportunities")
}

// ─── Drilling ─────────────────────────────────────────────────────────────────

model Well {
  id          String     @id @default(cuid())
  tenantId    String
  projectId   String
  code        String
  type        String
  utmE        Float?
  utmN        Float?
  utmZ        Float?
  depthCurrent Float     @default(0)
  depthTarget  Float
  bit         String?
  azimuth     Float?
  dip         Float?
  status      WellStatus @default(ACTIVE)
  lastUpdate  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id])
  drillLogs   DrillLog[]
  coreSamples CoreSample[]
  files       File[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("wells")
}

enum WellStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ALERT
}

model DrillLog {
  id        String   @id @default(cuid())
  wellId    String
  fromDepth Float
  toDepth   Float
  lithology String
  recovery  Float?
  rqd       Float?
  notes     String?
  loggedAt  DateTime
  loggedBy  String?
  createdAt DateTime @default(now())

  well Well @relation(fields: [wellId], references: [id], onDelete: Cascade)

  @@index([wellId])
  @@map("drill_logs")
}

model CoreSample {
  id         String   @id @default(cuid())
  wellId     String
  box        Int
  fromDepth  Float
  toDepth    Float
  recovery   Float?
  labResults Json?
  photoUrl   String?
  createdAt  DateTime @default(now())

  well Well @relation(fields: [wellId], references: [id], onDelete: Cascade)
  files File[]

  @@map("core_samples")
}

// ─── HSE ──────────────────────────────────────────────────────────────────────

model Incident {
  id          String         @id @default(cuid())
  tenantId    String
  projectId   String?
  type        IncidentType
  severity    IncidentSeverity
  description String
  location    String?
  injuredName String?
  status      IncidentStatus @default(OPEN)
  occurredAt  DateTime
  reportedBy  String?
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  files  File[]

  @@index([tenantId])
  @@map("incidents")
}

enum IncidentType {
  ACCIDENT
  NEAR_MISS
  ENVIRONMENTAL
  PROPERTY_DAMAGE
  SECURITY
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  CLOSED
}

model Permit {
  id          String       @id @default(cuid())
  tenantId    String
  projectId   String?
  type        String
  description String
  assignedTo  String?
  issuedAt    DateTime
  expiresAt   DateTime
  status      PermitStatus @default(PENDING)
  signatureUrl String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  files  File[]

  @@index([tenantId])
  @@map("permits")
}

enum PermitStatus {
  PENDING
  APPROVED
  ACTIVE
  EXPIRED
  REVOKED
}

model Certification {
  id         String    @id @default(cuid())
  userId     String
  type       String
  status     CertStatus @default(OK)
  issuedAt   DateTime?
  expiresAt  DateTime?
  documentUrl String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

enum CertStatus {
  OK
  WARNING
  EXPIRED
  NA
}

// ─── Fleet ────────────────────────────────────────────────────────────────────

model Equipment {
  id          String          @id @default(cuid())
  tenantId    String
  projectId   String?
  code        String
  type        String
  brand       String
  model       String
  hours       Float           @default(0)
  fuelRate    Float?
  status      EquipmentStatus @default(OPERATIONAL)
  lastMaint   DateTime?
  nextMaint   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  maintenances Maintenance[]
  files  File[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("equipment")
}

enum EquipmentStatus {
  OPERATIONAL
  MAINTENANCE
  OUT
  RETIRED
}

model Maintenance {
  id          String   @id @default(cuid())
  equipmentId String
  type        String
  description String
  cost        Decimal? @db.Decimal(12, 2)
  performedAt DateTime
  nextDue     DateTime?
  technician  String?
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@map("maintenances")
}

// ─── Field ────────────────────────────────────────────────────────────────────

model Visit {
  id        String      @id @default(cuid())
  tenantId  String
  projectId String
  type      String
  notes     String?
  lat       Float?
  lng       Float?
  status    VisitStatus @default(PENDING)
  visitedAt DateTime
  visitedBy String?
  signature String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id])
  files   File[]

  @@index([tenantId])
  @@map("visits")
}

enum VisitStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ─── Files (S3) ───────────────────────────────────────────────────────────────

model File {
  id          String      @id @default(cuid())
  tenantId    String
  projectId   String?
  wellId      String?
  coreSampleId String?
  visitId     String?
  incidentId  String?
  permitId    String?
  equipmentId String?
  key         String      @unique
  bucket      String
  filename    String
  mimeType    String
  size        Int
  category    FileCategory @default(DOCUMENT)
  uploadedBy  String?
  createdAt   DateTime    @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project    Project?    @relation(fields: [projectId], references: [id])
  well       Well?       @relation(fields: [wellId], references: [id])
  coreSample CoreSample? @relation(fields: [coreSampleId], references: [id])
  visit      Visit?      @relation(fields: [visitId], references: [id])
  incident   Incident?   @relation(fields: [incidentId], references: [id])
  permit     Permit?     @relation(fields: [permitId], references: [id])
  equipment  Equipment?  @relation(fields: [equipmentId], references: [id])

  @@index([tenantId])
  @@index([key])
  @@map("files")
}

enum FileCategory {
  PHOTO
  VIDEO
  DOCUMENT
  RAW_DATA
  REPORT
  SIGNATURE
  CORE_PHOTO
}

// ─── Webhooks ─────────────────────────────────────────────────────────────────

model Webhook {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  url       String
  events    String[]
  secret    String
  active    Boolean  @default(true)
  lastFiredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([tenantId])
  @@map("webhooks")
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  statusCode Int?
  response   String?
  attempts   Int      @default(1)
  deliveredAt DateTime?
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_deliveries")
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
